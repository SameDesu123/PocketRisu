{
  "id": "deepseek",
  "version": 1,
  "displayName": "DeepSeek",
  "adapterKind": "openai-compatible",
  "authKinds": ["bearer"],
  "endpointKinds": ["static"],
  "defaultHeaders": { "Content-Type": "application/json" },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "DeepSeek API key.",
      "required": true,
      "secret": true,
      "mapsTo": { "target": "auth", "path": "apiKey" }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Model identifier (e.g. deepseek-chat, deepseek-reasoner).",
      "required": true,
      "mapsTo": { "target": "body", "path": "model" }
    }
  ],
  "uiSchema": {
    "groups": [
      { "id": "credentials", "label": "Credentials", "order": 1 },
      { "id": "model", "label": "Model", "order": 2 }
    ],
    "fields": [
      { "key": "apiKey", "widget": "secret", "visibility": "basic", "group": "credentials", "order": 1 },
      { "key": "modelId", "widget": "text", "visibility": "basic", "group": "model", "order": 1, "placeholder": "deepseek-chat" }
    ]
  },
  "capabilities": ["streaming", "reasoning"],
  "sourceUrls": [
    "https://api-docs.deepseek.com/api/create-chat-completion"
  ]
}
