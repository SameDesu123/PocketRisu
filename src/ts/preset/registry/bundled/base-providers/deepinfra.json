{
  "id": "deepinfra",
  "version": 1,
  "displayName": "DeepInfra",
  "adapterKind": "openai-compatible",
  "authKinds": ["bearer"],
  "endpointKinds": ["static"],
  "defaultHeaders": { "Content-Type": "application/json" },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "DeepInfra API key.",
      "required": true,
      "secret": true,
      "mapsTo": { "target": "auth", "path": "apiKey" }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Model identifier accepted by DeepInfra (e.g. meta-llama/Meta-Llama-3.1-70B-Instruct).",
      "required": true,
      "mapsTo": { "target": "body", "path": "model" }
    }
  ],
  "uiSchema": {
    "groups": [
      { "id": "credentials", "label": "Credentials", "order": 1 },
      { "id": "model", "label": "Model", "order": 2 }
    ],
    "fields": [
      { "key": "apiKey", "widget": "secret", "visibility": "basic", "group": "credentials", "order": 1 },
      { "key": "modelId", "widget": "text", "visibility": "basic", "group": "model", "order": 1 }
    ]
  },
  "capabilities": ["streaming"],
  "sourceUrls": [
    "https://deepinfra.com/docs/advanced/openai_api"
  ]
}
