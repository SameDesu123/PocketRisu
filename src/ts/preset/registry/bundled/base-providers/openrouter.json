{
  "id": "openrouter",
  "version": 1,
  "displayName": "OpenRouter",
  "adapterKind": "openai-compatible",
  "authKinds": ["bearer"],
  "endpointKinds": ["static"],
  "defaultHeaders": { "Content-Type": "application/json" },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "OpenRouter API key (`sk-or-...`).",
      "required": true,
      "secret": true,
      "mapsTo": { "target": "auth", "path": "apiKey" }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Vendor/model identifier (e.g. anthropic/claude-sonnet-4.5).",
      "required": true,
      "mapsTo": { "target": "body", "path": "model" }
    }
  ],
  "uiSchema": {
    "groups": [
      { "id": "credentials", "label": "Credentials", "order": 1 },
      { "id": "model", "label": "Model", "order": 2 }
    ],
    "fields": [
      { "key": "apiKey", "widget": "secret", "visibility": "basic", "group": "credentials", "order": 1 },
      { "key": "modelId", "widget": "text", "visibility": "basic", "group": "model", "order": 1, "placeholder": "anthropic/claude-sonnet-4-5" }
    ]
  },
  "capabilities": ["streaming", "reasoning", "vision", "tools"],
  "sourceUrls": [
    "https://openrouter.ai/docs",
    "https://raw.githubusercontent.com/vercel/ai/main/packages/openrouter-provider/"
  ]
}
